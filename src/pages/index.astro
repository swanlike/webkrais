---
import Layout from '../layouts/Layout.astro';
import MachineGrid from '../components/MachineGrid.astro';
import { getCategoryHref, getMachineHref, getMachineImage, loadCatalog } from '../lib/catalog';

const catalog = await loadCatalog();
const heroMachine = catalog.featuredMachines[0] ?? catalog.machines[0];
---

<Layout
  title="webkrais | Modern machine catalog"
  description="Astro and Directus prototype for industrial machine catalogs."
  categories={catalog.categories}
>
  <section class="border-b border-stone-300/70">
    <div class="app-container mx-auto grid gap-10 px-6 py-8 lg:grid-cols-[1.05fr_0.95fr] lg:py-14">
      <div class="flex flex-col justify-between gap-8">
        <div class="space-y-6">
          <div class="hero-kicker">
            <span class="inline-block size-2 rounded-full bg-orange-500"></span>
            <span>Preline UI shell</span>
          </div>
          <h1 class="max-w-5xl text-5xl font-semibold leading-tight text-stone-950 lg:text-7xl">
            Product catalog for industrial tools with a cleaner base for fast prototyping.
          </h1>
          <p class="max-w-4xl text-base leading-7 text-stone-600 lg:text-lg">
            The app now centers on one catalog flow: pull machine data from Directus, fall back to curated mock data,
            and present it in a modern browsing experience that is easy to extend.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div class="stat-block">
            <span class="stat-value">{catalog.machines.length}</span>
            <span class="stat-label">machines</span>
          </div>
          <div class="stat-block">
            <span class="stat-value">{catalog.categories.length}</span>
            <span class="stat-label">categories</span>
          </div>
          <div class="stat-block">
            <span class="stat-value">{catalog.source}</span>
            <span class="stat-label">data source</span>
          </div>
        </div>

        <div class="flex flex-wrap gap-3">
          <a class="btn-primary" href={heroMachine ? getMachineHref(heroMachine) : '#catalog'}>
            Explore featured machine
          </a>
          <a class="btn-secondary" href="#catalog">Browse full catalog</a>
        </div>
      </div>

      {heroMachine && (
        <div class="surface-panel overflow-hidden">
          <img
            src={getMachineImage(heroMachine)}
            alt={heroMachine.name}
            class="aspect-[4/3] w-full object-cover"
            referrerpolicy="no-referrer"
          />
          <div class="grid gap-6 p-6 lg:grid-cols-[1fr_auto] lg:items-end">
            <div class="space-y-3">
              <p class="eyebrow">{heroMachine.marketing_name}</p>
              <h2 class="text-3xl font-semibold text-stone-950">{heroMachine.name}</h2>
              <p class="max-w-xl text-sm leading-6 text-stone-600">{heroMachine.description}</p>
            </div>
            <a class="text-sm font-medium text-orange-600 transition hover:text-stone-950" href={getMachineHref(heroMachine)}>
              Open details
            </a>
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="border-b border-stone-300/70 bg-white/55">
    <div class="app-container mx-auto px-6 py-10 lg:py-14">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-4xl space-y-2">
          <p class="section-label">Category routes</p>
          <h2 class="text-3xl font-semibold text-stone-950">Designed for direct navigation</h2>
          <p class="text-sm leading-6 text-stone-600">
            Each product group gets its own route, which keeps the prototype ready for search landing pages, campaign links and filtered navigation.
          </p>
        </div>

        <div class="flex flex-wrap gap-2">
          {catalog.categories.map((category) => (
            <a class="chip" href={getCategoryHref(category.id)}>
              <span>{category.name}</span>
              <span class="text-stone-400">{category.count}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-stone-300/70 bg-stone-950 text-white">
    <div class="app-container mx-auto grid gap-8 px-6 py-10 lg:grid-cols-[0.95fr_1.05fr] lg:py-14">
      <div class="space-y-4">
        <p class="section-label !text-orange-400">Why this shell works</p>
        <h2 class="text-3xl font-semibold text-white">Preline components, but still your own product surface.</h2>
        <p class="text-sm leading-6 text-stone-300">
          The catalog keeps content and routing in Astro, product data in Directus and interaction patterns from Preline UI. That gives you a cleaner runway for forms, filters and richer product detail blocks.
        </p>
      </div>

      <div class="hs-accordion-group space-y-3" data-hs-accordion-always-open>
        <div class="hs-accordion surface-panel !bg-white/95 !shadow-none" id="faq-one">
          <button class="hs-accordion-toggle inline-flex w-full items-center justify-between gap-x-3 px-5 py-4 text-start text-sm font-semibold text-stone-950" aria-expanded="true" aria-controls="faq-collapse-one">
            Directus is still the content source
            <svg class="hs-accordion-active:hidden block size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" /></svg>
            <svg class="hs-accordion-active:block hidden size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" /></svg>
          </button>
          <div id="faq-collapse-one" class="hs-accordion-content w-full overflow-hidden transition-[height] duration-300" role="region" aria-labelledby="faq-one">
            <div class="px-5 pb-5 pt-0 text-sm leading-6 text-stone-600">
              The app loads `Beveling_machines` from Directus and falls back to mock data only when the CMS is unavailable.
            </div>
          </div>
        </div>

        <div class="hs-accordion surface-panel !bg-white/95 !shadow-none" id="faq-two">
          <button class="hs-accordion-toggle inline-flex w-full items-center justify-between gap-x-3 px-5 py-4 text-start text-sm font-semibold text-stone-950 collapsed" aria-expanded="false" aria-controls="faq-collapse-two">
            Astro handles the route structure
            <svg class="hs-accordion-active:hidden block size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" /></svg>
            <svg class="hs-accordion-active:block hidden size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" /></svg>
          </button>
          <div id="faq-collapse-two" class="hs-accordion-content hidden w-full overflow-hidden transition-[height] duration-300" role="region" aria-labelledby="faq-two">
            <div class="px-5 pb-5 pt-0 text-sm leading-6 text-stone-600">
              Category routes and machine detail routes are generated statically, which keeps the prototype fast and deployment-friendly.
            </div>
          </div>
        </div>

        <div class="hs-accordion surface-panel !bg-white/95 !shadow-none" id="faq-three">
          <button class="hs-accordion-toggle inline-flex w-full items-center justify-between gap-x-3 px-5 py-4 text-start text-sm font-semibold text-stone-950 collapsed" aria-expanded="false" aria-controls="faq-collapse-three">
            Preline now powers the interaction layer
            <svg class="hs-accordion-active:hidden block size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" /></svg>
            <svg class="hs-accordion-active:block hidden size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" /></svg>
          </button>
          <div id="faq-collapse-three" class="hs-accordion-content hidden w-full overflow-hidden transition-[height] duration-300" role="region" aria-labelledby="faq-three">
            <div class="px-5 pb-5 pt-0 text-sm leading-6 text-stone-600">
              Mobile navigation and accordions now use Preline behaviors instead of plain static markup.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="catalog" class="app-container mx-auto px-6 py-10 lg:py-14">
    <MachineGrid
      machines={catalog.machines}
      categories={catalog.categories}
      title="Browse all machines"
      intro="The current prototype keeps content simple: a strong catalog overview, category routes and machine detail pages ready for Directus content."
    />
  </section>
</Layout>

