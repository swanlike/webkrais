---
import Layout from '../../layouts/Layout.astro';
import { getMachineImage, loadCatalog, loadMachines } from '../../lib/catalog';

export async function getStaticPaths() {
  const { machines } = await loadMachines();

  return machines.map((machine) => ({
    params: { id: machine.id.toString() },
  }));
}

const machineId = Astro.params.id ?? '';
const catalog = await loadCatalog();
const { machines } = await loadMachines();
const machine = machines.find((entry) => String(entry.id) === machineId);

if (!machine) {
  return Astro.redirect('/');
}

const categoryName =
  machine.grupa_narzedzi && typeof machine.grupa_narzedzi === 'object'
    ? machine.grupa_narzedzi.name
    : 'Industrial tooling';
---

<Layout
  title={`${machine.name} | webkrais`}
  description={`${machine.name} machine detail page.`}
  categories={catalog.categories}
  currentCategory={typeof machine.grupa_narzedzi === 'object' && machine.grupa_narzedzi ? String(machine.grupa_narzedzi.id) : undefined}
>
  <section class="border-b border-stone-300/70">
    <div class="app-container mx-auto px-6 py-8 lg:py-12">
      <a href="/" class="inline-flex items-center gap-2 text-sm text-stone-500 transition hover:text-orange-600">
        <span aria-hidden="true">‹</span>
        <span>Back to catalog</span>
      </a>
    </div>
  </section>

  <section class="app-container mx-auto px-6 py-10 lg:py-14">
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="overflow-hidden rounded-[8px] border border-white/70 bg-white shadow-[0_30px_80px_rgba(28,25,23,0.12)]">
        <img
          src={getMachineImage(machine)}
          alt={machine.name}
          class="aspect-[4/3] w-full object-cover"
          referrerpolicy="no-referrer"
        />
      </div>

      <div class="space-y-8">
        <div class="space-y-5">
          <div class="flex flex-wrap items-center gap-3">
            <span class="status-pill">{categoryName}</span>
            {machine.featured && <span class="eyebrow">Featured machine</span>}
          </div>

          <div class="space-y-3">
            <p class="section-label">{machine.marketing_name}</p>
            <h1 class="text-4xl font-semibold text-stone-950 lg:text-6xl">{machine.name}</h1>
            <p class="max-w-2xl text-base leading-7 text-stone-600">{machine.description}</p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="stat-block">
            <span class="stat-value">Directus</span>
            <span class="stat-label">ready content model</span>
          </div>
          <div class="stat-block">
            <span class="stat-value">Astro</span>
            <span class="stat-label">static route output</span>
          </div>
        </div>

        <div class="rounded-[8px] border border-stone-200 bg-white p-6 shadow-sm">
          <div class="space-y-3">
            <h2 class="text-xl font-semibold text-stone-950">Prototype inquiry block</h2>
            <p class="text-sm leading-6 text-stone-600">
              This section is intentionally lightweight for now. It gives sales and product teams a clean placeholder before real forms, CRM integration or tracked lead flows are added.
            </p>
          </div>

          <div class="mt-6 flex flex-wrap gap-3">
            <a class="btn-primary" href={`mailto:sales@webkrais.local?subject=${encodeURIComponent(`Inquiry about ${machine.name}`)}`}>
              Start inquiry
            </a>
            {typeof machine.grupa_narzedzi === 'object' && machine.grupa_narzedzi && (
              <a class="btn-secondary" href={`/category/${machine.grupa_narzedzi.id}`}>
                More in {machine.grupa_narzedzi.name}
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

